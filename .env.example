# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase overrides for production deployments

# Optional: protects /api/test-mariadb with x-admin-token
ADMIN_API_TOKEN=

# Optional: sent by the admin UI as x-admin-token for /api/test-mariadb
VITE_ADMIN_API_TOKEN=

# Optional: fail deploy when public health endpoint is not reachable
REQUIRE_PUBLIC_HEALTH=false

# Optional: webhook URL to notify deploy failures from GitHub Actions
DEPLOY_ALERT_WEBHOOK=

# Optional: SMTP settings for deploy email notifications (to cyuste@gmail.com)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Optional: deploy service name and release retention for rollback snapshots
DEPLOY_SERVICE_NAME=madridlive-app.service
KEEP_RELEASES=8

# Optional: pick a specific release folder under $DEPLOY_PATH/releases for rollback
# Example: ROLLBACK_RELEASE=release-20260704T120151Z-abaf795
ROLLBACK_RELEASE=

# MySQL persistence (Phase 1 migration)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Option A: JSON literal of a service account key (single-line JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: rely on GOOGLE_APPLICATION_CREDENTIALS file + set project explicitly
FIREBASE_PROJECT_ID=
# Optional Firestore DB ID (default: (default))
