# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REQUIRED in every deployed environment (prod and staging). server.ts also
# falls back to HOST=127.0.0.1 as defense in depth, but every real .env must
# set it explicitly so a future default change cannot expose the backend
# directly on the public IP.
# Incident: docs/PRODUCTION_OBSERVABILITY.md -> "Deploy Incident Closure 2026-07-12".
HOST=127.0.0.1

# Required for admin scripts/CI that call mutating /api/mysql endpoints with x-admin-token.
ADMIN_API_TOKEN=

# Required for browser sessions. Use a dedicated secret; ADMIN_API_TOKEN is never a fallback.
# Local environments that use browser login must set this independently too.
ADMIN_SESSION_SECRET=

# Required for browser admin login. Do not expose these as VITE_* variables.
ADMIN_LOGIN_EMAIL=
ADMIN_LOGIN_PASSWORD=

# Optional: override frontend API base for local debugging parity (e.g. https://madridliveapp.top/api/mysql)
VITE_MYSQL_API_BASE=
# Optional: dev-only proxy target used by Vite server for /api/mysql (avoids browser CORS in localhost)
VITE_DEV_PROXY_MYSQL_TARGET=

# Optional: comma-separated browser origins allowed to make cross-origin /api
# calls. Defaults to https://madridliveapp.top,https://staging.madridliveapp.top.
# Same-origin and non-browser clients (curl, CI) are unaffected.
CORS_ALLOWED_ORIGINS=

# Optional: fail deploy when public health endpoint is not reachable
REQUIRE_PUBLIC_HEALTH=false

# Optional: webhook URL to notify deploy failures from GitHub Actions
DEPLOY_ALERT_WEBHOOK=

# Optional: SMTP settings for deploy email notifications (to cyuste@gmail.com)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Password reset email (server-only; never expose as VITE_*).
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=false
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM=
APP_PUBLIC_BASE_URL=
# Use json in CI/e2e to avoid contacting a real SMTP server.
MAIL_TRANSPORT=
# Set to true ONLY to accept a self-signed TLS cert from the mail server
# (mail server on the same host without a public CA cert).
# Default/unset = strict certificate verification.
MAIL_TLS_INSECURE=

# Optional: deploy service name and release retention for rollback snapshots
DEPLOY_SERVICE_NAME=madridlive-app.service
KEEP_RELEASES=8

# Optional: pick a specific release folder under $DEPLOY_PATH/releases for rollback
# Example: ROLLBACK_RELEASE=release-20260704T120151Z-abaf795
ROLLBACK_RELEASE=

# MySQL persistence (active source of truth)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Legacy Firebase variables are not used by the active MySQL data path.
# Option A: JSON literal of a service account key (single-line JSON)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: rely on GOOGLE_APPLICATION_CREDENTIALS file + set project explicitly
FIREBASE_PROJECT_ID=
